{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@supabase/supabase-js": "^2.108.1",
    "@ted-voca/shared": "file:../../packages/shared",
    "expo": "~56.0.11",
    "expo-audio": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.6",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.17",
    "expo-router": "~56.2.10",
    "expo-secure-store": "^56.0.4",
    "expo-speech": "~56.0.3",
    "expo-speech-recognition": "^56.0.1",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint ."
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest-setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@ted-voca/shared$": "<rootDir>/../../packages/shared/src/index.ts",
      "^@react-native-async-storage/async-storage$": "@react-native-async-storage/async-storage/jest",
      "^@babel/runtime/(.+)$": "<rootDir>/node_modules/@babel/runtime/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|expo-.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|native-base|react-native-.*|zustand|@supabase/.*))"
    ]
  }
}
